# ───────────── Servidor ─────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ───────────── Supabase ─────────────
# URL do seu projeto (ex: https://xxxxxxxx.supabase.co)
SUPABASE_URL=
# Service role key (Settings → API → service_role, NÃO o anon key)
SUPABASE_SERVICE_ROLE_KEY=

# ───────────── Evolution API ─────────────
# Na Railway, o Evolution roda num serviço separado.
# Use a URL interna: http://<nome-do-servico>.railway.internal:8080
# Ou a URL pública: https://<seu-evolution>.up.railway.app
EVOLUTION_URL=
EVOLUTION_API_KEY=
# Nome da instância (você escolhe ao criar no Evolution Manager, ex: "agente")
EVOLUTION_INSTANCE=default

# ───────────── OpenAI ─────────────
# Obrigatório: geração de texto (gpt-4.1-mini), transcrição de áudio (whisper-1),
# análise de imagem (gpt-4o-mini). Pode também ser armazenado em agent_configs.
OPENAI_API_KEY=

# ───────────── Gemini (opcional) ─────────────
# Só necessário se você quiser analisar VÍDEOS.
# A chave é armazenada em agent_configs.gemini_api_key (não vai aqui).

# ───────────── Tunings ─────────────
# Intervalo do sweeper que reprocessa buffers travados (ms)
AGENT_BUFFER_SWEEPER_MS=20000
